<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="false">

  <extensions>
    <add assembly="NLog.Mongo"/>
  </extensions>

  <targets async="true">

    <!-- Konsol — tüm ortamlar -->
    <target name="console" xsi:type="Console"
            layout="${longdate}|${level:uppercase=true}|${scopeproperty:item=SessionId}|${logger}|${message} ${exception:format=tostring}"/>

    <!-- API + Infrastructure sistem logları -->
    <target name="mongo-system" xsi:type="Mongo"
            connectionString="${configsetting:name=ConnectionStrings.MongoLog}"
            databaseName="StudentManagementLogs"
            collectionName="ApplicationLogs">
      <field name="SessionId"  layout="${scopeproperty:item=SessionId}"/>
      <field name="Level"      layout="${level}"/>
      <field name="Logger"     layout="${logger}"/>
      <field name="Message"    layout="${message}"/>
      <field name="Exception"  layout="${exception:format=tostring}"/>
      <field name="Timestamp"  layout="${date:format=o}" bsonType="DateTime"/>
    </target>

    <!-- Agent karar logları -->
    <target name="mongo-agent" xsi:type="Mongo"
            connectionString="${configsetting:name=ConnectionStrings.MongoLog}"
            databaseName="StudentManagementLogs"
            collectionName="AgentLogs">
      <field name="SessionId"  layout="${scopeproperty:item=SessionId}"/>
      <field name="ToolName"   layout="${scopeproperty:item=ToolName}"/>
      <field name="Message"    layout="${message}"/>
      <field name="Timestamp"  layout="${date:format=o}" bsonType="DateTime"/>
    </target>

    <!-- MCP çalıştırma logları -->
    <target name="mongo-mcp" xsi:type="Mongo"
            connectionString="${configsetting:name=ConnectionStrings.MongoLog}"
            databaseName="StudentManagementLogs"
            collectionName="McpExecutionLogs">
      <field name="SessionId"    layout="${scopeproperty:item=SessionId}"/>
      <field name="ToolName"     layout="${scopeproperty:item=ToolName}"/>
      <field name="Parameters"   layout="${scopeproperty:item=ToolParameters}"/>
      <field name="Duration"     layout="${scopeproperty:item=ToolDuration}"/>
      <field name="Timestamp"    layout="${date:format=o}" bsonType="DateTime"/>
    </target>

  </targets>

  <rules>
    <!-- Infrastructure ve API logları → mongo-system + konsol -->
    <logger name="StudentManagement.Infrastructure.*" minlevel="Info"  writeTo="mongo-system,console" final="true"/>
    <logger name="StudentManagement.Api.*"            minlevel="Info"  writeTo="mongo-system,console" final="true"/>

    <!-- Agent logları → mongo-agent + konsol -->
    <logger name="StudentManagement.Agent.*"          minlevel="Debug" writeTo="mongo-agent,console"  final="true"/>

    <!-- MCP logları → mongo-mcp + konsol -->
    <logger name="StudentManagement.MCP.*"            minlevel="Debug" writeTo="mongo-mcp,console"    final="true"/>

    <!-- Trace/Debug yalnızca Development ortamında — production'da filtreler -->
    <logger name="*" minlevel="Info" writeTo="console"/>
  </rules>

</nlog>
